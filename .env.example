# ローカル開発用。本番（Render など）ではダッシュボードの Environment に設定する
OPENAI_API_KEY=sk-your-key-here

# 任意: 日替わりクラスコードのトークン署名用（未設定時は OPENAI_API_KEY を利用）
# GATE_SECRET=your-random-secret

# 任意: クラスコードロック（true/false）。Render では render.yaml で false 推奨
# GATE_LOCK_ENABLED=false

# 任意: Flask セッション用（本番では必ずランダムな値を設定）
# FLASK_SECRET_KEY=your-random-secret
